# ─────────────────────────────────────────────────────────────────────────────
# Strategic OSINT Radar — External Configuration
# Copy this file to config.env and fill in your API keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Proxy & SSL Settings ─────────────────────────────────────────────────────
# 企業プロキシ環境下で実行する場合は以下を設定してください。
HTTP_PROXY=
HTTPS_PROXY=

# SSLインスペクション等により「CERTIFICATE_VERIFY_FAILED」が出る場合は false に設定
SSL_VERIFY=true

# ── Cloudflare Radar API Token ────────────────────────────────────────────────
# 必須: Cloudflare Radar (Read)
CF_API_TOKEN=

# ── OpenWeatherMap API Key ────────────────────────────────────────────────────
# 必須: 気象ノイズフィルター用
OWM_API_KEY=

# ── Additional Sensor API Keys ────────────────────────────────────────────────
# NASA FIRMS API (必須: 熱異常検知用。 https://firms.modaps.eosdis.nasa.gov/api/ から取得)
NASA_FIRMS_API_KEY=

# ThreatFox API (任意: abuse.chはキーなしでも1日分のIoC取得が可能ですが、将来拡張用として用意)
THREATFOX_API_KEY=

# ── System Parameters ─────────────────────────────────────────────────────────
CURRENT_DATE_RANGE=1d
BASELINE_DATE_RANGE=7d
CACHE_EXPIRY=900

AIRSPACE_ANOMALY_THRESHOLD=0.40
AIRSPACE_CLOSURE_THRESHOLD=0.05
AIRSPACE_WINDOW=20

# 軍事緊張前兆の実測値: -12〜-15。侵攻直前: -18〜-25。早期警戒のため-15.0に引き下げ。
GDELT_TONE_ALERT_THRESHOLD=-15.0
GDELT_HISTORY_WINDOW=28

CONVERGENCE_DUAL_BONUS=1
CONVERGENCE_FULL_BONUS=2
DEFCON_HYSTERESIS_CYCLES=1

DEFAULT_CORE=TW
DEFAULT_CORRELATES=JP,US
DEFAULT_ADVERSARIES=CN,RU,KP
DEFAULT_PINS=TW,JP,US,RU,CN,AU,IR,IL,UA,IN

# ── Deep Pattern Analysis ────────────────────────────────────────────────────

# --- A. DDoS Acceleration Engine ---
# 脅威スコア2階微分のAmbushパターン判定Zスコア閾値（デフォルト: 2.0）
AMBUSH_ZSCORE_THRESHOLD=2.0
# 速度/加速度計算に使用するローリングウィンドウ点数（デフォルト: 5）
DERIVATIVE_WINDOW=5
# 発信源同期性判定のタイムデルタ上限（ミリ秒, デフォルト: 500）
SYNC_DELTA_MS=500
# 同期性スコアのC2判定閾値 (0.0〜1.0, デフォルト: 0.70)
SYNC_C2_THRESHOLD=0.70

# --- B. Narrative Burst Detector (RSS Z-Score) ---
# Z-Scoreナラティブバースト警戒閾値（デフォルト: 2.0）
NARRATIVE_ZSCORE_ALERT=2.0
# 重大ナラティブ作戦判定閾値（デフォルト: 3.0）
NARRATIVE_ZSCORE_CRITICAL=3.0
# Z-Scoreベースライン保持日数（デフォルト: 30）
NARRATIVE_BASELINE_DAYS=30
# RSSフェッチ間隔（秒, デフォルト: 1800 = 30分）
NARRATIVE_POLL_INTERVAL=1800

# --- C. Sequence Scorer ---
# エスカレーション連鎖検証ウィンドウ（秒, デフォルト: 86400 = 24h）
SEQUENCE_WINDOW=86400
# 完全連鎖確認ボーナス点数（デフォルト: 3）
SEQUENCE_FULL_BONUS=3
# 部分連鎖（3イベント）ボーナス点数（デフォルト: 1）
SEQUENCE_PARTIAL_BONUS=1

# --- D. Maritime AIS Sensor ---
# AIS Dark Gap 判定時間（秒, デフォルト: 3600 = 1h）
AIS_DARK_GAP_THRESHOLD=3600
# 海峡付近の停泊異常判定半径（km, デフォルト: 50）
AIS_ANCHOR_RADIUS_KM=50

# --- E. ISR Hotspot Sensor ---
# ISR機種フィルター (ICAO type codes, カンマ区切り)
ISR_ICAO_TYPES=RC135,RC-135,E3,E-3,RQ4,RQ-4,P8,P-8,EP3,EP-3,U2,TR1,E8,E-8,J-STARS
# ISRサージ判定閾値（ホットスポット圏内の対象機数, デフォルト: 3）
ISR_SURGE_THRESHOLD=3

# --- F. OpenSky Network 認証 ---
# 2026-03-18 以降 Basic 認証廃止。OAuth2 Client Credentials フローを使用。
# opensky-network.org のアカウント設定 → API Client で Client ID/Secret を発行。
# 設定すると上限 400 → 4000 req/day に増加。未設定時は匿名アクセス。
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# リクエスト間の最小待機秒数 (デフォルト: 10s、認証済みは 5s まで短縮可)
OPENSKY_MIN_INTERVAL=10

# ── GreyNoise API Key ──────────────────────────────────────────────────────────
# 取得先: https://www.greynoise.io/plans/community (Community 無料 / Enterprise 有償)
# Community キーの場合: GNQL Stats は使用不可。noise_ratio は算出されず gnql_tier=community_limited となる。
# Enterprise キーの場合: GNQL Stats API (v2/experimental/gnql/stats) によるノイズ抑制が有効になる。
GREYNOISE_API_KEY=

# ── Check-Host.net ────────────────────────────────────────────────────────────
# 使用するグローバルノードのカンマ区切りリスト
# 利用可能なノード一覧: https://check-host.net/nodes/hosts
# 空欄の場合はデフォルトノードセットを使用
CHECKHOST_NODES=jp1.node.check-host.net,us1.node.check-host.net,de1.node.check-host.net,nl1.node.check-host.net,fr1.node.check-host.net
# Check-Host 確認間隔（秒）。DDoS加速度スパイク時のみ起動するため長めでOK
CHECKHOST_POLL_INTERVAL=600
# HTTPレスポンス成功とみなす最大レイテンシ（ms）
CHECKHOST_TIMEOUT_MS=3000

# ── TelegramMirrorSensor ───────────────────────────────────────────────────────
# tgstat.com / telemetr.io スクレイピング間隔（秒）
TELEGRAM_MIRROR_POLL_INTERVAL=900
# 攻撃宣言パターンを検出するキーワード（正規表現対応）
TELEGRAM_ATTACK_KEYWORDS="target,attack,ddos,http flood,under attack,down,offline,op,#target"
