# ─────────────────────────────────────────────────────────────────────────────
# Strategic OSINT Radar — External Configuration
# Copy this file to config.env and fill in your API keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Proxy & SSL Settings ─────────────────────────────────────────────────────
# Set the following if running behind a corporate proxy.
HTTP_PROXY=
HTTPS_PROXY=

# Set to false if you get CERTIFICATE_VERIFY_FAILED due to SSL inspection.
SSL_VERIFY=true

# ── Cloudflare Radar API Token ────────────────────────────────────────────────
# Required: Cloudflare Radar (Read)
CF_API_TOKEN=

# ── OpenWeatherMap API Key ────────────────────────────────────────────────────
# Required: used for weather noise filtering
OWM_API_KEY=

# ── Additional Sensor API Keys ────────────────────────────────────────────────
# NASA FIRMS API (Required: thermal anomaly detection. Get key at https://firms.modaps.eosdis.nasa.gov/api/)
NASA_FIRMS_API_KEY=

# ThreatFox API (Optional: abuse.ch allows 1-day IoC fetch without a key, but reserved for future expansion)
THREATFOX_API_KEY=

# ── System Parameters ─────────────────────────────────────────────────────────
CURRENT_DATE_RANGE=1d
BASELINE_DATE_RANGE=7d
CACHE_EXPIRY=900

AIRSPACE_ANOMALY_THRESHOLD=0.40
AIRSPACE_CLOSURE_THRESHOLD=0.05
AIRSPACE_WINDOW=20

# Observed values preceding military tension: -12 to -15. Pre-invasion: -18 to -25. Lowered to -15.0 for early warning.
GDELT_TONE_ALERT_THRESHOLD=-15.0
GDELT_HISTORY_WINDOW=28

CONVERGENCE_DUAL_BONUS=1
CONVERGENCE_FULL_BONUS=2
DEFCON_HYSTERESIS_CYCLES=1

DEFAULT_CORE=TW
DEFAULT_CORRELATES=JP,US
DEFAULT_ADVERSARIES=CN,RU,KP
DEFAULT_PINS=TW,JP,US,RU,CN,AU,IR,IL,UA,IN

# ── Deep Pattern Analysis ────────────────────────────────────────────────────

# --- A. DDoS Acceleration Engine ---
# Z-score threshold for Ambush pattern detection on the 2nd derivative of threat score (default: 2.0)
AMBUSH_ZSCORE_THRESHOLD=2.0
# Rolling window size used for velocity/acceleration calculation (default: 5)
DERIVATIVE_WINDOW=5
# Maximum time delta for source synchronization detection (ms, default: 500)
SYNC_DELTA_MS=500
# C2 determination threshold for synchronization score (0.0–1.0, default: 0.70)
SYNC_C2_THRESHOLD=0.70

# --- B. Narrative Burst Detector (RSS Z-Score) ---
# Z-score threshold for narrative burst alert (default: 2.0)
NARRATIVE_ZSCORE_ALERT=2.0
# Z-score threshold for critical narrative operation determination (default: 3.0)
NARRATIVE_ZSCORE_CRITICAL=3.0
# Number of days to retain Z-score baseline (default: 30)
NARRATIVE_BASELINE_DAYS=30
# RSS fetch interval (seconds, default: 1800 = 30 min)
NARRATIVE_POLL_INTERVAL=1800

# --- C. Sequence Scorer ---
# Escalation chain verification window (seconds, default: 86400 = 24h)
SEQUENCE_WINDOW=86400
# Bonus points for full chain confirmation (default: 3)
SEQUENCE_FULL_BONUS=3
# Bonus points for partial chain (3 events) (default: 1)
SEQUENCE_PARTIAL_BONUS=1

# --- D. Maritime AIS Sensor ---
# AIS Dark Gap detection threshold (seconds, default: 3600 = 1h)
AIS_DARK_GAP_THRESHOLD=3600
# Anchoring anomaly detection radius near straits (km, default: 50)
AIS_ANCHOR_RADIUS_KM=50

# --- E. ISR Hotspot Sensor ---
# ISR aircraft type filter (ICAO type codes, comma-separated)
ISR_ICAO_TYPES=RC135,RC-135,E3,E-3,RQ4,RQ-4,P8,P-8,EP3,EP-3,U2,TR1,E8,E-8,J-STARS
# ISR surge detection threshold (number of target aircraft within hotspot radius, default: 3)
ISR_SURGE_THRESHOLD=3

# --- F. OpenSky Network Authentication ---
# Basic auth deprecated after 2026-03-18. Use OAuth2 Client Credentials flow.
# Generate Client ID/Secret from opensky-network.org account settings → API Client.
# When configured, request limit increases from 400 → 4000 req/day. Anonymous access used if unset.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# Minimum wait time between requests (seconds, default: 10s; can be reduced to 5s when authenticated)
OPENSKY_MIN_INTERVAL=10

# ── GreyNoise API Key ──────────────────────────────────────────────────────────
# Get key at: https://www.greynoise.io/plans/community (Community: free / Enterprise: paid)
# Community key: GNQL Stats unavailable. noise_ratio not calculated; gnql_tier=community_limited.
# Enterprise key: GNQL Stats API (v2/experimental/gnql/stats) noise suppression enabled.
GREYNOISE_API_KEY=

# ── Check-Host.net ────────────────────────────────────────────────────────────
# Comma-separated list of global nodes to use
# Available nodes: https://check-host.net/nodes/hosts
# Leave blank to use the default node set
CHECKHOST_NODES=jp1.node.check-host.net,us1.node.check-host.net,de1.node.check-host.net,nl1.node.check-host.net,fr1.node.check-host.net
# Check-Host polling interval (seconds). Can be set long since it only triggers on DDoS acceleration spikes.
CHECKHOST_POLL_INTERVAL=600
# Maximum latency (ms) to consider an HTTP response successful
CHECKHOST_TIMEOUT_MS=3000

# ── TelegramMirrorSensor ───────────────────────────────────────────────────────
# tgstat.com / telemetr.io scraping interval (seconds)
TELEGRAM_MIRROR_POLL_INTERVAL=900
# Keywords to detect attack declaration patterns (regex supported)
TELEGRAM_ATTACK_KEYWORDS="target,attack,ddos,http flood,under attack,down,offline,op,#target"
